{
    "name": "mihaighita/heartland-retail",
    "description": "A PHP client library for the Heartland Retail (retail.heartland.us) REST API",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "heartland",
        "retail",
        "pos",
        "api",
        "rest",
        "ecommerce",
        "inventory",
        "point-of-sale"
    ],
    "authors": [
        {
            "name": "Mihai Ghita",
            "homepage": "https://github.com/mihaighita"
        }
    ],
    "homepage": "https://github.com/mihaighita/heartland-retail-php",
    "support": {
        "issues": "https://github.com/mihaighita/heartland-retail-php/issues",
        "source": "https://github.com/mihaighita/heartland-retail-php"
    },
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "HeartlandRetail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HeartlandRetail\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
